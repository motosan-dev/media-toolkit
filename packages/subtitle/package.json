{
  "name": "@motosan-dev/subtitle",
  "version": "0.0.1",
  "description": "Multi-platform video subtitle fetcher — agent-friendly, pipe-safe",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@motosan-dev/core": "workspace:*"
  },
  "files": ["dist"],
  "license": "MIT"
}
